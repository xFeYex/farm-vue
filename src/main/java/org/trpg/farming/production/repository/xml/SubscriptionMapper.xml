<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.production.dao.SubscriptionRepository">

    <select id="findActiveByResourceId" resultType="com.example.production.entity.Subscription">
        SELECT
            id,
            resource_id,
            tenant_user_id,
            status,
            start_time,
            end_time,
            created_at,
            updated_at
        FROM subscription
        WHERE resource_id = #{resourceId}
          AND status = 'ACTIVE'
        ORDER BY id DESC
        LIMIT 1
    </select>

</mapper>